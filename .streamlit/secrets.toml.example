# Neo4j Aura Agent Configuration
# Copy this file to secrets.toml and fill in your credentials
# IMPORTANT: secrets.toml is gitignored - never commit it

# Aura Agent endpoint
agent_endpoint = "https://api.neo4j.io/v2beta1/organizations/YOUR_ORG_ID/projects/YOUR_PROJECT_ID/agents/YOUR_AGENT_ID/invoke"

# OAuth2 Client Credentials (from Neo4j Aura Console)
# The app will use these to generate a bearer token for each user session
neo4j_client_id = "your_client_id_here"
neo4j_client_secret = "your_client_secret_here"
